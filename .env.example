# OpenAI API key (required)
OPENAI_API_KEY=

# OpenAI model names
OPENAI_CHAT_MODEL=gpt-4o
OPENAI_REWRITER_MODEL=gpt-4o-mini

# Qdrant
QDRANT_HOST=qdrant
QDRANT_PORT=6333

# PostgreSQL
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_DB=pgfoodwine
POSTGRES_USER=pgfoodwine
POSTGRES_PASSWORD=pgfoodwine

# Grafana (optional, defaults shown)
GRAFANA_PORT=3000
